# claripy.ast.base stub — Base AST node

from __future__ import annotations

from typing import Any, Union


class Base:
    """Base class for all claripy AST nodes."""

    # Bit-width of the bitvector (None for Bool)
    length: int
    args: tuple[Any, ...]
    op: str

    # Arithmetic operators (return same type for BV)
    def __add__(self, other: Union[Base, int]) -> Base: ...
    def __radd__(self, other: Union[Base, int]) -> Base: ...
    def __sub__(self, other: Union[Base, int]) -> Base: ...
    def __rsub__(self, other: Union[Base, int]) -> Base: ...
    def __mul__(self, other: Union[Base, int]) -> Base: ...
    def __rmul__(self, other: Union[Base, int]) -> Base: ...
    def __floordiv__(self, other: Union[Base, int]) -> Base: ...
    def __mod__(self, other: Union[Base, int]) -> Base: ...
    def __lshift__(self, other: Union[Base, int]) -> Base: ...
    def __rshift__(self, other: Union[Base, int]) -> Base: ...
    def __and__(self, other: Union[Base, int]) -> Base: ...
    def __rand__(self, other: Union[Base, int]) -> Base: ...
    def __or__(self, other: Union[Base, int]) -> Base: ...
    def __ror__(self, other: Union[Base, int]) -> Base: ...
    def __xor__(self, other: Union[Base, int]) -> Base: ...
    def __rxor__(self, other: Union[Base, int]) -> Base: ...
    def __invert__(self) -> Base: ...
    def __neg__(self) -> Base: ...

    # Comparison operators → Bool AST
    def __eq__(self, other: object) -> Base: ...  # type: ignore[override]
    def __ne__(self, other: object) -> Base: ...  # type: ignore[override]
    def __lt__(self, other: Union[Base, int]) -> Base: ...
    def __le__(self, other: Union[Base, int]) -> Base: ...
    def __gt__(self, other: Union[Base, int]) -> Base: ...
    def __ge__(self, other: Union[Base, int]) -> Base: ...

    def __hash__(self) -> int: ...
    def __repr__(self) -> str: ...
    def __bool__(self) -> bool: ...  # raises ClaripyOperationError at runtime for symbolic


class Bool(Base):
    """Boolean AST node."""
    ...
